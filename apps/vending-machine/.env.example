# x402 V2 — required for paid routes
X402_PAY_TO_ADDRESS=0xYourWalletAddressHere

# Testnet (no signup): https://x402.org/facilitator
# Production + CDP Bazaar: https://api.cdp.coinbase.com/platform/v2/x402 + CDP_API_KEY_* below
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK_MODE=base-sepolia

# Production
PUBLIC_BASE_URL=https://your-app.vercel.app

# Required when X402_FACILITATOR_URL is CDP (seller verify/settle)
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# Phase 0.5 caps / rate limits (optional)
# Raise for premium Kronos / future bundle-market (default lib cap is 0.05)
# X402_MAX_PRICE_USD=0.50
# X402_UNPAID_RATE_LIMIT=30
# X402_UNPAID_RATE_WINDOW_MS=60000

# Phase 0.6 — full /api/admin/stats (Bearer token)
# ANALYTICS_TOKEN=

# Kronos premium atom — Railway apps/kronos-api (or portalv2 local)
# Same secret on Vercel + Railway; never commit real values
# KRONOS_API_URL=https://your-kronos-api.up.railway.app
# KRONOS_API_SECRET=

# x402 V2 — required for paid routes
X402_PAY_TO_ADDRESS=0xYourWalletAddressHere

# Testnet (no signup): https://x402.org/facilitator
# Production + CDP Bazaar: https://api.cdp.coinbase.com/platform/v2/x402 + CDP_API_KEY_* below
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK_MODE=base-sepolia

# Production
PUBLIC_BASE_URL=https://your-app.vercel.app

# Required when X402_FACILITATOR_URL is CDP (seller verify/settle)
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=